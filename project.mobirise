              ".line": {
                "width": "5rem",
                "height": "3px",
                "background": "linear-gradient(90deg, @primaryColor, @secondaryColor)",
                "display": "inline-block"
              }
            },
            ".title-wrap": {
              "padding-left": "0",
              "padding-right": "0"
            },
            ".image-wrap": {
              "overflow": "hidden",
              "width": "100%",
              "img": {
                "width": "100%",
                "height": "100%",
                "z-index": "1",
                "transition": "all 0.5s ease-in-out",
                "&:hover": {
                  "-webkit-transform": "scale(1.05)",
                  "transform": "scale(1.05)"
                }
              }
            },
            ".content-section": {
              "padding": "3rem"
            },
            ".btn": {
